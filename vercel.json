{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html",   "use": "@vercel/static" },
    { "src": "tracker.html", "use": "@vercel/static" },
    { "src": "*.json",       "use": "@vercel/static" },
    { "src": "data/**",      "use": "@vercel/static" },
    { "src": "*.png",        "use": "@vercel/static" },
    { "src": "vendor/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/route/([a-z])", "dest": "/api/route/[letter].js?letter=$1" },
    { "src": "/api/version",       "dest": "/api/version.js" },
    { "src": "/tracker",           "dest": "/tracker.html" },
    { "src": "/",                  "dest": "/index.html" },
    { "src": "/(.*)",              "dest": "/$1" }
  ]
}
