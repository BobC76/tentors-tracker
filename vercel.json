{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "verify.html", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.geojson", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "vendor/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/routee", "dest": "/api/routee.js" },
    { "src": "/", "dest": "/verify.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
